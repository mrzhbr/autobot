# Copy this file to .env and fill in real values.
# Keep .env local. Do not commit secrets.

# GitHub auth used by Autobot to read issues, comment, push branches, and open
# draft pull requests.
#
# Option A: personal access token or fine-grained token.
GITHUB_TOKEN=
#
# Option B: GitHub App installation auth. Used when GITHUB_TOKEN is empty.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/absolute/path/to/private-key.pem
#
# Bot login used by watch mode and self-comment filtering.
# For a GitHub App, this usually looks like your-app-slug[bot].
AGENT_LOGIN=your-bot-login

# LLM provider. Use OpenAI, Anthropic, or OpenRouter.
LLM_PROVIDER=openai

# OpenAI option.
OPENAI_API_KEY=sk-your-openai-key-here
TRIAGE_MODEL=gpt-4.1
IMPLEMENT_MODEL=gpt-4.1
REVIEW_MODEL=gpt-4.1
REVIEW_MODELS=gpt-4.1
LLM_HTTP_TIMEOUT_SECONDS=240
LLM_HTTP_RETRIES=2

# Implementation harness. "legacy" preserves the current typed LLM edit-plan path.
# "pi" runs the Pi RPC adapter inside the Docker sandbox. SANDBOX_IMAGE must
# provide the pi CLI, and SANDBOX_NETWORK must allow LLM egress.
# "openhands" is reserved for the external baseline adapter.
IMPLEMENT_HARNESS=legacy
HARNESS_LLM_PROVIDER=
HARNESS_MODEL=
HARNESS_TIMEOUT_SECONDS=1800
HARNESS_MAX_RESTARTS=1

# Optional read-only planning stage. When enabled, Autobot starts a separate Pi
# RPC session with read-only tools before test authoring and implementation.
PLANNER_ENABLED=0
PLANNER_HARNESS=pi
PLANNER_LLM_PROVIDER=
PLANNER_MODEL=

# Anthropic option. If using Anthropic, set LLM_PROVIDER=anthropic and replace
# the model names above with Anthropic-compatible models.
ANTHROPIC_API_KEY=

# OpenRouter option. If using OpenRouter, set LLM_PROVIDER=openrouter and use
# OpenRouter model IDs such as openai/gpt-4.1 or anthropic/claude-sonnet-4.
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Autobot

# Live Docker sandbox. Dry-run does not need Docker egress.
# IMPLEMENT_HARNESS=pi needs egress, for example bridge.
# IMPLEMENT_HARNESS=pi also needs a SANDBOX_IMAGE with the pi CLI installed.
SANDBOX_BACKEND=docker-copy
SANDBOX_IMAGE=autobot-pi-sandbox
SANDBOX_NETWORK=bridge

# Optional run limits.
MAX_REVIEW_ROUNDS=3
COMMENT_LIMIT_PER_RUN=1
MAX_ISSUE_TOKENS=
MAX_ISSUE_DOLLARS=

# Optional pricing. Required if MAX_ISSUE_DOLLARS is set.
# Prices are dollars per 1K tokens.
TRIAGE_INPUT_PRICE_PER_1K=
TRIAGE_OUTPUT_PRICE_PER_1K=
IMPLEMENT_INPUT_PRICE_PER_1K=
IMPLEMENT_OUTPUT_PRICE_PER_1K=
TEST_INPUT_PRICE_PER_1K=
TEST_OUTPUT_PRICE_PER_1K=
REVIEW_INPUT_PRICE_PER_1K=
REVIEW_OUTPUT_PRICE_PER_1K=
